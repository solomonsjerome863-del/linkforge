# LinkForge - AI-Powered Internal Linking for SEO

# Database (Vercel Postgres provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://linkforge.digital"

# Public app URL (used for checkout redirects)
NEXT_PUBLIC_APP_URL="https://linkforge.digital"

# Admin access — set to YOUR email to unlock the Admin Dashboard
NEXT_PUBLIC_ADMIN_EMAIL="your-email@example.com"
ADMIN_EMAIL="your-email@example.com"

# Paystack — https://dashboard.paystack.com (ZAR — South African account)
# Step 1: Log into your Paystack dashboard
# Step 2: Go to Settings → API Keys & Webhooks → copy your Secret Key
# Step 3: Go to Plans — your two plans are already created:
#   - "LinkForge Pro" — R999/month (Plan Code: PLN_mwy4kw4pmlj2b2q)
#   - "Business" — R2,455/month (Plan Code: PLN_f08wc8zj8cu71f6)
# Step 4: Go to Settings → API Keys & Webhooks → Webhooks
#   - Add endpoint: https://linkforge.digital/api/billing/webhook
#   - Subscribe to: charge.success, subscription.create, subscription.not_renew, subscription.disable, subscription.enable
PAYSTACK_SECRET_KEY=""
PAYSTACK_PLAN_PRO="PLN_mwy4kw4pmlj2b2q"
PAYSTACK_PLAN_BUSINESS="PLN_f08wc8zj8cu71f6"

# z-ai-web-dev-sdk (for AI features - set automatically on Vercel)
# ZAI_API_KEY=
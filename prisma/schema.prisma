generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  plan          String    @default("starter") // starter | pro | business | enterprise
  usageLinks    Int       @default(0)
  usageQueries  Int       @default(0)
  emailVerified Boolean   @default(false)
  resetToken    String?
  resetTokenExpiry DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sites Site[]
}

model Site {
  id          String   @id @default(cuid())
  name        String
  url         String
  platform    String   @default("wordpress") // wordpress | shopify | webflow | ghost | custom
  status      String   @default("pending")  // pending | crawling | ready | error
  pageLimit   Int      @default(100)
  pagesCount  Int      @default(0)
  linksCount  Int      @default(0)
  lastCrawled DateTime?
  error       String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pages       Page[]
  suggestions LinkSuggestion[]
  crawlJobs   CrawlJob[]
}

model Page {
  id          String   @id @default(cuid())
  url         String
  title       String
  content     String   // raw HTML content
  textContent String   // stripped text for embedding
  headings    String   // JSON array of heading strings
  wordCount   Int      @default(0)
  status      String   @default("active") // active | excluded
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sourceSuggestions  LinkSuggestion[] @relation("SourcePage")
  targetSuggestions  LinkSuggestion[] @relation("TargetPage")
}

model LinkSuggestion {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sourcePageId  String
  sourcePage    Page     @relation("SourcePage", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPageId  String
  targetPage    Page     @relation("TargetPage", fields: [targetPageId], references: [id], onDelete: Cascade)
  anchorText    String
  surroundingText String?
  score         Float    @default(0)
  status        String   @default("pending") // pending | approved | rejected | applied
  appliedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([siteId, status])
  @@index([sourcePageId])
  @@index([targetPageId])
}

model CrawlJob {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // pending | running | completed | failed
  pagesFound  Int      @default(0)
  pagesSaved  Int      @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  siteId    String
  date      String   // YYYY-MM-DD
  totalLinks    Int @default(0)
 orphanPages   Int @default(0)
 avgLinksPerPage Float @default(0)
 topKeywords   String // JSON
  createdAt DateTime @default(now())

  @@unique([siteId, date])
  @@index([siteId, date])
}
